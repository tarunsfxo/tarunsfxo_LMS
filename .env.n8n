# n8n Automation Configurations
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_SECRET=dev-webhook-secret
N8N_ENABLED=true

# Redis Connection (Used for async message queuing)
REDIS_URL=redis://localhost:6379/0

# OpenAI API Settings (Optional - falls back to local patterns gracefully)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Pluggable Email Service Configuration
EMAIL_PROVIDER=smtp # options: console, smtp, sendgrid
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=developer
SMTP_PASSWORD=dummy_password
SMTP_FROM=noreply@tarunsfxo-lms.com
SENDGRID_API_KEY=
SENDGRID_FROM=
