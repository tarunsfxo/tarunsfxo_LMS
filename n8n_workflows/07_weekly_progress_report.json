{
  "name": "07 Weekly Progress Report",
  "nodes": [
    {
      "parameters": {
        "triggerTimes": {
          "value": [
            {
              "mode": "custom",
              "cronExpression": "0 9 * * 0"
            }
          ]
        }
      },
      "name": "Weekly Schedule Trigger",
      "type": "n8n-nodes-base.cron",
      "typeVersion": 1,
      "position": [
        100,
        200
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.LMS_API_BASE_URL}}/n8n/webhook/weekly-report",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Webhook-Secret",
              "value": "={{$env.N8N_WEBHOOK_SECRET}}"
            }
          ]
        }
      },
      "name": "Flask Weekly Report Webhook",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [
        300,
        200
      ]
    }
  ],
  "connections": {
    "Weekly Schedule Trigger": {
      "main": [
        [
          {
            "node": "Flask Weekly Report Webhook",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": true,
  "settings": {}
}